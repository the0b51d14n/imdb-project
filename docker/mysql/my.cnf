# ══════════════════════════════════════════════════════════════════════════════
#  docker/mysql/my.cnf — Supinfo.TV
# ══════════════════════════════════════════════════════════════════════════════

[mysqld]
# ── Encodage ──────────────────────────────────────────────────────────────────
character-set-server=utf8mb4
collation-server=utf8mb4_unicode_ci

# ── Sécurité ──────────────────────────────────────────────────────────────────
# Désactive le chargement local de fichiers (LOAD DATA LOCAL INFILE)
local_infile=0

# ── Performances ──────────────────────────────────────────────────────────────
innodb_buffer_pool_size=256M
innodb_log_file_size=64M
max_connections=100
query_cache_size=0
query_cache_type=0

# ── Logs ──────────────────────────────────────────────────────────────────────
slow_query_log=1
slow_query_log_file=/var/log/mysql/slow.log
long_query_time=2

[client]
default-character-set=utf8mb4

[mysql]
default-character-set=utf8mb4
