# ══════════════════════════════════════════════════════════════════════════════
#  .env.example — Supinfo.TV
#  Copiez ce fichier en .env et remplissez les valeurs réelles.
#  ❌ Ne jamais commiter le .env avec de vraies valeurs.
# ══════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_SECRET=changeme_32chars_minimum_random_string

# ── Base de données ────────────────────────────────────────────────────────────
DB_HOST=mysql
DB_PORT=3306
DB_NAME=supinfotv
DB_USER=supinfotv_user
DB_PASS=changeme_strong_password

# ── TMDB API ──────────────────────────────────────────────────────────────────
# Obtenez votre clé sur https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# ── Sécurité prix (HMAC SHA-256) ──────────────────────────────────────────────
# Générez avec : php -r "echo bin2hex(random_bytes(32));"
PRICE_HMAC_SECRET=changeme_64hex_chars_price_hmac_secret

# ── CSRF ──────────────────────────────────────────────────────────────────────
# Générez avec : php -r "echo bin2hex(random_bytes(32));"
CSRF_SECRET=changeme_64hex_chars_csrf_secret

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX_ATTEMPTS=5
RATE_LIMIT_DECAY_MINUTES=15

# ── Mail (SMTP) ───────────────────────────────────────────────────────────────
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USER=your_smtp_username
MAIL_PASS=your_smtp_password
MAIL_FROM=noreply@supinfo.tv
MAIL_FROM_NAME=Supinfo.TV
